# Infrastructure
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_PORT=27017
REDIS_PORT=6379

# Shared
JWT_SECRET=replace_with_strong_secret
REDIS_URL=redis://redis:6379

# Service Mongo URLs
IDENTITY_MONGODB_URI=mongodb://admin:admin123@mongo:27017/identitydb?authSource=admin
JOB_MONGODB_URI=mongodb://admin:admin123@mongo:27017/jobdb?authSource=admin
APPLICANT_MONGODB_URI=mongodb://admin:admin123@mongo:27017/applicantdb?authSource=admin
SCREENING_MONGODB_URI=mongodb://admin:admin123@mongo:27017/screeningdb?authSource=admin

# Applicant service (validates public job uploads against job-service)
JOB_SERVICE_URL=http://localhost:8082
# Local disk folder for uploaded files (default: apps/applicant-service/src/uploads).
# In Docker, docker-compose sets UPLOAD_DIR to /app/apps/applicant-service/src/uploads and bind-mounts ./apps/applicant-service/src/uploads — keep that in sync; do not point UPLOAD_DIR elsewhere unless you change the volume.
# UPLOAD_DIR=apps/applicant-service/src/uploads

# Ports
API_GATEWAY_PORT=8080
IDENTITY_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
APPLICANT_SERVICE_PORT=8083
SCREENING_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

# Frontend origins allowed by API Gateway CORS (comma-separated). Include every URL you open the app from (localhost vs 127.0.0.1, port, Vite 5173, etc.).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173

ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
RESET_TOKEN_EXPIRY_MINUTES=15

# Email / SMTP
APP_BASE_URL=http://localhost:3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
EMAIL_FROM=UmuravaLens <no-reply@example.com>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
