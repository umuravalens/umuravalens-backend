# Infrastructure
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_PORT=27017
REDIS_PORT=6379

# Shared
JWT_SECRET=replace_with_strong_secret
REDIS_URL=redis://redis:6379

# Service Mongo URLs
AUTH_MONGODB_URI=mongodb://admin:admin123@mongo:27017/authdb?authSource=admin
JOB_MONGODB_URI=mongodb://admin:admin123@mongo:27017/jobdb?authSource=admin
APPLICANT_MONGODB_URI=mongodb://admin:admin123@mongo:27017/applicantdb?authSource=admin
SCREENING_MONGODB_URI=mongodb://admin:admin123@mongo:27017/screeningdb?authSource=admin

# Ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
APPLICANT_SERVICE_PORT=8083
SCREENING_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
RESET_TOKEN_EXPIRY_MINUTES=15
