# Infrastructure
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_secure_password_here
MONGO_PORT=27017
REDIS_PORT=6379

# Shared
# Generate a secure secret using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
REDIS_URL=redis://redis:6379
DEFAULT_SOURCE_NAME=Umurava
DEFAULT_SOURCE_CODE=umrv_plt

# Service Mongo URLs (Internal Docker Network)
# Format: mongodb://user:password@host:port/dbname?authSource=admin
IDENTITY_MONGODB_URI=mongodb://admin:admin_password@mongo:27017/identitydb?authSource=admin
AUTH_MONGODB_URI=mongodb://admin:admin_password@mongo:27017/identitydb?authSource=admin
JOB_MONGODB_URI=mongodb://admin:admin_password@mongo:27017/jobdb?authSource=admin
APPLICANT_MONGODB_URI=mongodb://admin:admin_password@mongo:27017/applicantdb?authSource=admin
SCREENING_MONGODB_URI=mongodb://admin:admin_password@mongo:27017/screeningdb?authSource=admin

# Internal Service communication
JOB_SERVICE_URL=http://job-service:8082
IDENTITY_SERVICE_URL=http://identity-service:8081
APPLICANT_SERVICE_URL=http://applicant-service:8083
SCREENING_SERVICE_URL=http://screening-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085
WORKER_SERVICE_URL=http://worker-service:8086

# Ports
API_GATEWAY_PORT=8080
IDENTITY_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
APPLICANT_SERVICE_PORT=8083
SCREENING_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
WORKER_SERVICE_PORT=8086

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Token Settings
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
RESET_TOKEN_EXPIRY_MINUTES=15

# Email / SMTP
APP_BASE_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_SECURE=false
EMAIL_FROM=UmuravaLens <your_email@gmail.com>

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com